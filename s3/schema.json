{
    "openapi": "3.0.0",
    "info": {
        "title": "ScraperTools",
        "version": "1.0.0"
    },
    "paths": {
        "/scrape_deals": {
            "post": {
                "operationId": "scrape_deals",
                "description": "Fetches a retailer page URL and uses Claude to extract products with significant discounts. Returns a structured list of deals to be passed directly to save_deals.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "url",
                                    "retailer",
                                    "category"
                                ],
                                "properties": {
                                    "url": {
                                        "type": "string",
                                        "description": "Full URL of the retailer sale or category page"
                                    },
                                    "retailer": {
                                        "type": "string",
                                        "description": "Retailer identifier e.g. nike or macys"
                                    },
                                    "category": {
                                        "type": "string",
                                        "description": "Product category e.g. sneakers hoodies dresses"
                                    },
                                    "min_discount_pct": {
                                        "type": "string",
                                        "description": "Minimum discount percentage to include. Defaults to 30"
                                    },
                                    "audience": {
                                        "type": "string",
                                        "description": "Target audience for the products e.g. men"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Deals extracted successfully"
                    }
                }
            }
        },
        "/save_deals": {
            "post": {
                "operationId": "save_deals",
                "description": "Saves deals to DynamoDB. Accepts the exact response shape returned by scrape_deals.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "retailer",
                                    "category",
                                    "deals"
                                ],
                                "properties": {
                                    "retailer": {
                                        "type": "string",
                                        "description": "Retailer identifier e.g. nike or macys"
                                    },
                                    "category": {
                                        "type": "string",
                                        "description": "Product category e.g. sneakers"
                                    },
                                    "dealsFound": {
                                        "type": "string",
                                        "description": "Number of deals found as returned by scrape_deals"
                                    },
                                    "deals": {
                                        "type": "string",
                                        "description": "JSON stringified array of deal objects returned from scrape_deals"
                                    },
                                    "audience": {
                                        "type": "string",
                                        "description": "Target audience for the products e.g. men"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Deals saved to DynamoDB successfully"
                    }
                }
            }
        }
    }
}